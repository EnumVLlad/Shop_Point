<main class="dashboard-shell">
  <section class="panel deals-page">
    <div class="panel-header">
      <div>
        <span class="eyebrow"><%= t("admin.eyebrow") %></span>
        <h1><%= t("admin.title") %></h1>
      </div>
      <%= link_to t("admin.user_dashboard"), dashboard_path, class: "button button-secondary" %>
    </div>

    <p class="page-lead"><%= t("admin.lead") %></p>

    <section class="stats-grid">
      <% @admin_stats.each do |stat| %>
        <%= link_to stat[:path], class: "stat-card admin-stat-link" do %>
          <span><%= stat[:label] %></span>
          <strong><%= stat[:value] %></strong>
          <small><%= t("admin.overview") %></small>
        <% end %>
      <% end %>
    </section>
  </section>
</main>
