<main class="dashboard-shell">
  <section class="hero-card">
    <div class="hero-content">
      <span class="eyebrow"><%= t("dashboard.eyebrow") %></span>
      <h1><%= t("dashboard.title") %></h1>
      <p><%= t("dashboard.description") %></p>
      <div class="hero-actions">
        <%= link_to t("dashboard.view_transactions"), "#transactions", class: "button button-primary" %>
        <%= link_to t("dashboard.process_webhook"), "#webhooks", class: "button button-secondary" %>
        <%= link_to t("dashboard.special_deals"), deals_path, class: "button button-deals" %>
      </div>
    </div>
    <div class="points-card">
      <span class="points-label"><%= t("dashboard.current_balance") %></span>
      <strong><%= number_with_delimiter(@customer.points_balance) %></strong>
      <span class="tier-badge"><%= @tier&.name || t("dashboard.starter") %> <%= t("dashboard.tier_suffix") %></span>
      <div class="progress-track">
        <div class="progress-bar" style="width: <%= @tier_progress %>%"></div>
      </div>
      <small><%= @next_tier ? t("dashboard.points_to_tier", points: number_with_delimiter(@points_to_next_tier), tier: @next_tier.name) : t("dashboard.top_tier") %></small>
    </div>
  </section>

  <section class="stats-grid">
    <% @stats.each do |stat| %>
      <article class="stat-card">
        <span><%= stat[:label] %></span>
        <strong><%= stat[:value] %></strong>
        <small><%= stat[:trend] %></small>
      </article>
    <% end %>
  </section>

  <section class="content-grid">
    <article class="panel" id="transactions">
      <div class="panel-header">
        <div>
          <span class="eyebrow"><%= t("dashboard.transactions.eyebrow") %></span>
          <h2><%= t("dashboard.transactions.title") %></h2>
        </div>
        <%= link_to t("dashboard.transactions.export_csv"), "#", class: "button button-ghost" %>
      </div>

      <div class="transaction-list">
        <% @transactions.each do |transaction| %>
          <div class="transaction-item">
            <div>
              <strong><%= transaction.title %></strong>
              <span><%= transaction.description %></span>
            </div>
            <div class="transaction-meta">
              <strong><%= number_with_delimiter(transaction.points) %></strong>
              <span><%= transaction.status %></span>
              <small><%= t("dashboard.transactions.ago", time: time_ago_in_words(transaction.created_at)) %></small>
            </div>
          </div>
        <% end %>
      </div>
    </article>

    <aside class="panel action-panel" id="webhooks">
      <span class="eyebrow"><%= t("dashboard.webhooks.eyebrow") %></span>
      <h2><%= t("dashboard.webhooks.title") %></h2>
      <p><%= t("dashboard.webhooks.description") %></p>
      <div class="workflow-list">
        <span><%= t("dashboard.webhooks.receive") %></span>
        <span><%= t("dashboard.webhooks.calculate") %></span>
        <span><%= t("dashboard.webhooks.update") %></span>
        <span><%= t("dashboard.webhooks.broadcast") %></span>
      </div>
      <%= link_to t("dashboard.webhooks.docs"), "#", class: "button button-primary button-wide" %>
    </aside>
  </section>
</main>
