<main class="dashboard-shell">
  <section class="panel deals-page">
    <div class="panel-header">
      <div>
        <span class="eyebrow"><%= t("deals.eyebrow") %></span>
        <h1><%= t("deals.title") %></h1>
      </div>
      <%= link_to t("deals.back"), root_path, class: "button button-secondary" %>
    </div>

    <p class="page-lead"><%= t("deals.lead") %></p>

    <div class="deals-grid">
      <% @deals.each do |deal| %>
        <article class="deal-card">
          <span class="tier-badge"><%= deal[:badge] %></span>
          <h2><%= deal[:title] %></h2>
          <p><%= deal[:description] %></p>
          <%= link_to t("deals.view_offer"), "#", class: "button button-primary button-wide" %>
        </article>
      <% end %>
    </div>
  </section>
</main>
