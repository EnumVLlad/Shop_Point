<h2><%= t("forms.sign_up") %></h2>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <p><%= f.label :email, t("forms.email") %></p>
    <p><%= f.email_field :email, autofocus: true, autocomplete: "email" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password, t("forms.password") %></p>
    <% if @minimum_password_length %>
      <p><em>(<%= t("forms.characters_minimum", count: @minimum_password_length) %>)</em></p>
    <% end %>
    <p><%= f.password_field :password, autocomplete: "new-password" %></p>
  </div>

  <div class="field">
    <p><%= f.label :password_confirmation, t("forms.password_confirmation") %></p>
    <p><%= f.password_field :password_confirmation, autocomplete: "new-password" %></p>
  </div>

  <div class="actions">
    <%= f.submit t("forms.sign_up") %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
