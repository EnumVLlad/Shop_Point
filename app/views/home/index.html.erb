<main class="dashboard-shell">
  <section class="hero-card public-hero">
    <div class="hero-content">
      <span class="eyebrow"><%= t("home.eyebrow") %></span>
      <h1><%= t("home.title") %></h1>
      <p><%= t("home.description") %></p>
      <div class="hero-actions">
        <%= link_to t("home.create_account"), new_user_registration_path, class: "button button-deals" %>
        <%= link_to t("home.sign_in"), new_user_session_path, class: "button button-secondary" %>
        <%= link_to t("home.view_public_deals"), deals_path, class: "button button-primary" %>
      </div>
    </div>
    <div class="points-card public-card">
      <span class="points-label"><%= t("home.bonus_label") %></span>
      <strong>500</strong>
      <span class="tier-badge"><%= t("home.starter_points") %></span>
      <p><%= t("home.bonus_description") %></p>
    </div>
  </section>

  <section class="deals-grid public-deals">
    <% @public_deals.each do |deal| %>
      <article class="deal-card">
        <span class="eyebrow"><%= t("home.store_offer") %></span>
        <h2><%= deal[:title] %></h2>
        <p><%= deal[:description] %></p>
      </article>
    <% end %>
  </section>
</main>
